# ==============================
# Pipeline service settings
# ==============================

# Comma-separated folders to watch (SMB/local paths)
WATCH_PATHS=\\10.1.1.43\eap_recipe_tracebility\WBK_ConnX Elite

# MySQL connection shared by pipeline and web
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=change-me
MYSQL_DATABASE=ksbody_analysis
MYSQL_CHARSET=utf8mb4

# Debounce behavior for filesystem events
DEBOUNCE_SETTLE_SECONDS=5
DEBOUNCE_POLL_SECONDS=1
DEBOUNCE_STABLE_CHECKS=2

# Scanner and runtime files
SCAN_INTERVAL=300
LOG_FILE=logs/recipe_import.log
STATE_FILE=state/processed_files.json

# ==============================
# Web service settings
# ==============================

# Web host/port/mode
APP_HOST=0.0.0.0
APP_PORT=12010
APP_MODE=dev
APP_DEBUG=false

# Comma-separated CORS origins
APP_CORS_ORIGINS=http://localhost:5173

# Optional Oracle connection
ORACLE_DSN=
ORACLE_USER=
ORACLE_PASSWORD=

# Recipe traceability SMB settings
RECIPE_TRACE_SMB_HOST=10.1.1.43
RECIPE_TRACE_SMB_SHARE=eap_recipe_tracebility
RECIPE_TRACE_SMB_USER=tracerecipe
RECIPE_TRACE_SMB_PASSWORD=change-me
RECIPE_TRACE_SMB_MACHINE_FOLDER=WBK_ConnX Elite
