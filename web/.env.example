# === 應用層級 ===
APP_PORT=12010                    # 單一監聽端口
APP_HOST=0.0.0.0                  # 綁定位址
APP_MODE=dev                      # 環境標識 (dev / prod)
APP_DEBUG=false                   # 正式環境禁止 true
APP_CORS_ORIGINS=http://localhost:5173  # CORS 允許來源，逗號分隔，禁止 "*"

# === MySQL 資料庫 ===
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=change-me
MYSQL_DATABASE=ksbody_analysis
MYSQL_CHARSET=utf8mb4

# === Oracle 良率資料庫 (選用) ===
ORACLE_DSN=
ORACLE_USER=
ORACLE_PASSWORD=

# === Recipe 追溯 SMB 連線 ===
RECIPE_TRACE_SMB_HOST=10.1.1.43
RECIPE_TRACE_SMB_SHARE=eap_recipe_tracebility
RECIPE_TRACE_SMB_USER=tracerecipe
RECIPE_TRACE_SMB_PASSWORD=change-me
